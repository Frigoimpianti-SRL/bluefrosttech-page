FTP_HOST=server301.web-hosting.com
FTP_USER=your_cpanel_username
FTP_PASSWORD=your_ftp_password

# ftp (port 21) or sftp (Namecheap shared hosting often uses port 21098)
DEPLOY_PROTOCOL=ftp
FTP_PORT=21

# For SFTP on Namecheap:
# DEPLOY_PROTOCOL=sftp
# FTP_PORT=21098

# Remote folder for the website root
# Use /public_html for most cPanel accounts.
# If FTP already opens inside public_html, use /
FTP_REMOTE_PATH=/public_html

# Set to true only if your host requires explicit FTPS
FTP_SECURE=false

# Optional: verbose FTP log for debugging
# FTP_VERBOSE=true
